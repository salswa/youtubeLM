# Supabase — new API key system (NOT the legacy anon/service_role keys)
# Copy this file to .env.local and fill in values from your Supabase project.

# Project URL (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key (sb_publishable_...) — browser-safe, replaces the legacy anon key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key (sb_secret_...) — SERVER ONLY, never prefix with NEXT_PUBLIC.
# Replaces the legacy service_role key.
SUPABASE_SECRET_KEY=

# Google Gemini API key  — SERVER ONLY.
GEMINI_API_KEY=
